# Backend base URL used by the Next.js route handler proxy (`/api/*`).
# This value is server-side only, so it can safely stay as loopback.
BACKEND_API_BASE=http://127.0.0.1:8000

# Optional: when set, the browser will call backend directly instead of same-origin proxy.
# - leave empty to use same-origin proxy (`/api/*`)
# - set to "auto" to use current hostname with port 8000 (e.g. http(s)://<host>:8000)
# - or set to a full URL like http://192.168.1.10:8000
# NEXT_PUBLIC_API_BASE=
